def get_valid_score(prompt, max_score):
    while True:
        try:
            score = float(input(prompt))
            if 0 <= score <= max_score:
                return score
            print(f"Error: Enter a value between 0 and {max_score}")
        except ValueError:
            print("Error: Please enter a number only")


def get_multiple_scores(category, count):
    total_score = 0
    total_max = 0

    for i in range(1, count + 1):
        while True:
            try:
                max_score = float(input(f"{category} {i} max score: "))
                if max_score > 0:
                    break
                print("Max score must be greater than 0")
            except ValueError:
                print("Enter a valid number")

        score = get_valid_score(f"{category} {i} score /{max_score}: ", max_score)

        total_score += score
        total_max += max_score

    return total_score, total_max


def get_weights():
    while True:
        try:
            print("\nEnter weights (must total 1.0 or 100)")
            quiz_w = float(input("Quiz weight: "))
            act_w = float(input("Activity weight: "))
            rec_w = float(input("Recitation weight: "))
            exam_w = float(input("Exam weight: "))

            total = quiz_w + act_w + rec_w + exam_w

            if total == 1.0:
                return quiz_w, act_w, rec_w, exam_w
            elif total == 100:
                return quiz_w/100, act_w/100, rec_w/100, exam_w/100
            else:
                print("Error: Weights must total 1.0 or 100\n")
        except ValueError:
            print("Error: Enter numbers only\n")


def calculate_term(term_name):
    print(f"\n--- {term_name.upper()} ---")

    quiz_count = int(input("How many quizzes? "))
    act_count = int(input("How many activities? "))
    rec_count = int(input("How many recitations? "))

    exam_max = float(input("Max score for exam: "))

    # get weights
    quiz_w, act_w, rec_w, exam_w = get_weights()

    # get scores
    quiz_total, quiz_max_total = get_multiple_scores("Quiz", quiz_count)
    act_total, act_max_total = get_multiple_scores("Activity", act_count)
    rec_total, rec_max_total = get_multiple_scores("Recitation", rec_count)

    exam = get_valid_score(f"Exam /{exam_max}: ", exam_max)

    # percentages
    quiz_pct = (quiz_total / quiz_max_total) * 100 if quiz_max_total else 0
    act_pct = (act_total / act_max_total) * 100 if act_max_total else 0
    rec_pct = (rec_total / rec_max_total) * 100 if rec_max_total else 0
    exam_pct = (exam / exam_max) * 100

    # final grade
    final_grade = round(
        quiz_pct * quiz_w +
        act_pct * act_w +
        rec_pct * rec_w +
        exam_pct * exam_w
    )

    print(f"\nFinal Grade ({term_name}): {final_grade}\n")


# main loop
while True:
    grade = input("What are you grading for? (prelims, midterms, finals, exit): ").lower()

    if grade in ["prelims", "midterms", "finals"]:
        calculate_term(grade)

    elif grade == "exit":
        print("Thanks for using Martin's grading system!")
        print("Exiting System...")
        break

    else:
        print("Invalid input. Try again.\n")
